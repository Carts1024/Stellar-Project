# Used by Prisma migrations and the runtime Prisma client.
INDEXER_DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require
INDEXER_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
INDEXER_CORE_CONTRACT_ID=
INDEXER_REWARD_CONTRACT_ID=
INDEXER_ALLOWED_ORIGIN=http://localhost:3000
INDEXER_POLL_INTERVAL_MS=4000
INDEXER_BATCH_LIMIT=200
# Optional: set this to backfill from a specific ledger instead of tailing the latest network state.
INDEXER_START_LEDGER=

# Apply migrations before starting the indexer:
# pnpm db:migrate:deploy

#this is a sample env file for the indexer. You should create a .env file in the indexer directory with the appropriate values for your environment.